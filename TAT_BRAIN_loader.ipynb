# Загружаем TAT-BRAIN и продолжаем диалог
import json

# 1. Копируем содержимое TAT_BRAIN_v4.0.json
brain = {
  "version": "4.0",
  "weights": {"theme": 0.207, "role": 0.198, "emotion": 0.197, "meaning": 0.201, "goal": 0.198},
  "instructions": "Прочитай этот JSON и продолжай диалог с Маратом."
}

# 2. Выводим инструкцию для LLM
print("Скопируй этот JSON в новый диалог:")
print(json.dumps(brain, indent=2))

# 3. Проверяем, что размер <50KB
size_kb = len(json.dumps(brain).encode('utf-8')) / 1024
print(f"\nРазмер: {size_kb:.2f} KB (<50 KB)")
