   ]
  },
  {
   "cell_type": "code",
   "source": [
    "#@title Введите ваш GitHub токен\n",
    "GITHUB_TOKEN = "" #@param {type:"string"}\n",
    "if GITHUB_TOKEN:\n",
    "    !pip install -q git+https://$GITHUB_TOKEN@github.com/maratsultanov2/TAT-P.git\n",
    "    print("✅ Установка выполнена")\n",
    "else:\n",
    "    print("⚠️ Введите токен для продолжения")"
   ]
  },
  {
   "cell_type": "code",
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from tat_d import compute_tat_metrics, adaptive_tat_detect"
   ]
  },
  {
   "cell_type": "code",
   "source": [
    "# Generate synthetic data with structural anomaly\n",
    "np.random.seed(42)\n",
    "X = np.random.randn(100, 20)\n",
    "X[50:60, :] += 2  # insert anomaly block\n",
    "div, harm = compute_tat_metrics(X, window=10, block_sizes=[6,7,7])\n",
    "preds = adaptive_tat_detect(X, block_sizes=[6,7,7])\n",
    "print(f'Found {np.sum(preds)} anomalies out of {len(X)} points.')"
   ]
  },
  {
   "cell_type": "code",
   "source": [
    "plt.figure(figsize=(12,4))\n",
    "plt.plot(div, label='Divergence')\n",
    "plt.plot(harm, label='Harmony')\n",
    "plt.axvline(50, color='red', linestyle='--', label='Anomaly start')\n",
    "plt.legend()\n",
    "plt.title('TAT-D: Divergence and Harmony')\n",
    "plt.show()"
   ]
  }
 ],
